rules_version = '2';

// TailorTeX — Cloud Storage rules
//
// 参照フォーマット契約(フロント public/js/assets.js と共有):
//   資産キー = ファイル内容の SHA-256(重複排除。同一ファイルは1回だけ保存)
//   Storage パス = docs/{docId}/assets/{sha256}.{ext}
//   参照文字列   = asset:{docId}/{sha256}.{ext}   (assets.js が Storage URL に解決)
//
// アクセス制御は Firestore の docs/{docId}.access マップ({uid: role}) と整合させる。
//   read  : その doc のメンバー(owner / editor / commenter / viewer)
//   write : owner / editor のみ(commenter / viewer は不可)
//   未認証 : 一律拒否
//   サイズ : 1ファイル 50MB 未満(write 時。delete では request.resource == null)
//
// 後方互換: 旧モデル(ownerUid / collaborators)のメンバーも許可する。
// superadmin(request.auth.token.role == 'superadmin')は全権。
//
// 注: Storage ルールのメソッドは read / write のみ(write が create/update/delete を包含)。
//     delete では request.resource が null になるため、サイズ判定は null ガードする。

service firebase.storage {
  match /b/{bucket}/o {

    // ---- 共通ヘルパ ----
    function isSignedIn() {
      return request.auth != null;
    }
    function isSuperadmin() {
      // Storage ルールでは未定義プロパティ参照が例外になるため 'role' の存在を先に確認する。
      return request.auth != null
        && 'role' in request.auth.token
        && request.auth.token.role == 'superadmin';
    }

    // 親 doc(Firestore docs/{docId})を参照する。
    // firestore.get は存在しない doc で失敗するため、必ず firestore.exists で先にガードする。
    function docExists(docId) {
      return firestore.exists(/databases/(default)/documents/docs/$(docId));
    }
    function docData(docId) {
      return firestore.get(/databases/(default)/documents/docs/$(docId)).data;
    }

    // 新モデル(フェーズ14): access マップ {uid: role}。
    // Storage ルールは不在キーの参照が例外になるため、key 存在を確認してから索引する
    // (未メンバーは null を返して旧モデル判定 isLegacyMember へフォールスルーさせる)。
    function accessRole(docId) {
      return ('access' in docData(docId)
              && docData(docId).access is map
              && request.auth.uid in docData(docId).access)
        ? docData(docId).access[request.auth.uid]
        : null;
    }
    // 旧モデル(フェーズ7): ownerUid / collaborators
    function isLegacyMember(docId) {
      return ('ownerUid' in docData(docId) && docData(docId).ownerUid == request.auth.uid)
        || ('collaborators' in docData(docId)
            && docData(docId).collaborators is list
            && request.auth.uid in docData(docId).collaborators);
    }

    // read できるメンバー: owner / editor / commenter / viewer(または旧メンバー)
    function canReadAsset(docId) {
      return isSignedIn() && docExists(docId)
        && (accessRole(docId) in ['owner', 'editor', 'commenter', 'viewer']
            || isLegacyMember(docId));
    }
    // write できるメンバー: owner / editor のみ(または旧メンバー)
    function canWriteAsset(docId) {
      return isSignedIn() && docExists(docId)
        && (accessRole(docId) in ['owner', 'editor']
            || isLegacyMember(docId));
    }
    // サイズ上限: アップロード時のみ判定(delete では request.resource == null)
    function withinSizeLimit() {
      return request.resource == null
        || request.resource.size < 50 * 1024 * 1024;
    }

    // ---- 資産: docs/{docId}/assets/{fileName}(fileName = {sha256}.{ext}) ----
    match /docs/{docId}/assets/{fileName} {
      allow read: if isSuperadmin() || canReadAsset(docId);
      allow write: if (isSuperadmin() || canWriteAsset(docId)) && withinSizeLimit();
    }

    // ---- それ以外は一律拒否(明示。既定拒否の再確認) ----
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
