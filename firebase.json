{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "server.js",
      "mcp-server.js",
      "cloud/**",
      "test/**",
      "work/**"
    ],
    "rewrites": [
      {
        "source": "/compile",
        "run": { "serviceId": "word-latex-compile", "region": "asia-northeast1" }
      },
      {
        "source": "/compile-accessible",
        "run": { "serviceId": "word-latex-compile", "region": "asia-northeast1" }
      },
      {
        "source": "/admin/**",
        "run": { "serviceId": "word-latex-compile", "region": "asia-northeast1" }
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "cloud/storage.rules"
  },
  "emulators": {
    "auth": { "port": 9099 },
    "firestore": { "port": 8080 },
    "storage": { "port": 9199 },
    "hosting": { "port": 5000 },
    "ui": { "enabled": true },
    "singleProjectMode": true
  }
}
